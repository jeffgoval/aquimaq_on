        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"status\": \"pending\"}",
        "options": {}
      },
      "id": "n_pending",
      "name": "Transferir p/ Pendente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 160]
    }
